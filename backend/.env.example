# Copy this file to .env and fill in values.

ENV=development
DEBUG=true

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# SQLite by default. Point at Postgres in production, e.g.:
# DATABASE_URL=postgresql://user:pass@host:5432/research_copilot
DATABASE_URL=sqlite:///./research_copilot.db

# LLM configuration. If GROQ_API_KEY is left blank, the app runs in
# offline "mock" mode so the workflow is still fully runnable end-to-end.
LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
LLM_MAX_TOKENS=1500
LLM_TIMEOUT_SECONDS=60

# Workflow tuning
MAX_QUALITY_RETRIES=1
WEBSITE_FETCH_TIMEOUT=8
WEBSITE_FETCH_MAX_CHARS=6000

LOG_LEVEL=INFO


JWT_SECRET_KEY=change-this-to-a-long-random-string
JWT_EXPIRE_MINUTES=1440
RATE_LIMIT_PER_MINUTE=60/minute